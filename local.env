# ===========================================
# Portfolio — Environment Variables
# ===========================================

# ------ Core ------
# Public-facing URL of the site (used for SEO canonical URLs, OpenGraph, sitemap)
NEXT_PUBLIC_URL=http://localhost:3000/

# Google Analytics measurement ID
NEXT_PUBLIC_ANALYTICS_ID=abcdefghijk

# ------ Dev.to Integration ------
# Dev.to username for fetching articles (Articles section + individual article pages)
NEXT_PUBLIC_DEVTO_USERNAME=lucasheartcliff

# ------ GitHub Integration ------
NEXT_PUBLIC_GITHUB_USERNAME=lucasheartcliff
# Personal access token (classic) with public_repo scope
# Generate at https://github.com/settings/tokens
GITHUB_TOKEN=

# ------ Build ------
# Set to 'true' to enable webpack bundle analyzer (yarn build-stats)
# ANALYZE=true

# Node environment (automatically set by Next.js — do not override in production)
# NODE_ENV=development
